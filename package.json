{
  "name": "nayamo",
  "version": "1.0.0",
  "description": "Nayamo E-Commerce Platform - Full Stack",
  "private": true,
  "workspaces": [
    "backend",
    "client",
    "admin"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:client\" \"npm run dev:admin\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:client": "cd client && npm run dev",
    "dev:admin": "cd admin && npm run dev",
    "install:all": "npm install && cd backend && npm install && cd ../client && npm install && cd ../admin && npm install",
    "build:client": "cd client && npm run build",
    "build:admin": "cd admin && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Anshul0563/Nayamo.git"
  },
  "keywords": [
    "ecommerce",
    "earrings",
    "jewellery",
    "mern-stack"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Anshul0563/Nayamo/issues"
  },
  "homepage": "https://github.com/Anshul0563/Nayamo#readme",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
