{
  "name": "nayamo",
  "version": "1.0.0",
  "description": "Nayamo E-Commerce Backend API",
  "main": "server.js",
  "scripts": {
    "test": "jest --coverage --detectOpenHandles",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "pm2:start": "pm2 start pm2.config.js",
    "pm2:stop": "pm2 stop pm2.config.js",
    "pm2:restart": "pm2 restart pm2.config.js",
    "pm2:logs": "pm2 logs nayamo-api",
    "lint": "eslint ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Anshul0563/Nayamo.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Anshul0563/Nayamo/issues"
  },
  "homepage": "https://github.com/Anshul0563/Nayamo#readme",
  "dependencies": {
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dompurify": "^3.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.4.1",
    "jsdom": "^26.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.1",
    "mongoose": "^9.4.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "razorpay": "^2.9.6",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "./jest.setup.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "controllers/**/*.js",
      "services/**/*.js",
      "middleware/**/*.js",
      "models/**/*.js",
      "utils/**/*.js",
      "!**/node_modules/**"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "verbose": true,
    "forceExit": true
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
