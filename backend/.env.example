NODE_ENV=production
PORT=5000

# Database
MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/nayamo?retryWrites=true&amp;w=majority

# JWT (openssl rand -base64 32)
JWT_SECRET=your-32-char-secret
JWT_REFRESH_SECRET=your-32-char-refresh-secret

# Cloudinary (required)
CLOUDINARY_CLOUD_NAME=demo
CLOUDINARY_API_KEY=926946677463422
CLOUDINARY_API_SECRET=your-secret

# Gmail SMTP (App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SECURE=false
CONTACT_EMAIL=support@nayamo.com

# CORS
CORS_ORIGINS=https://admin-[project].vercel.app,https://client-[project].vercel.app,http://localhost:3000,http://localhost:3001

# Optional - Disable if no keys
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# Optional - Disable if no token
# DELHIVERY_TOKEN=your-token

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500

