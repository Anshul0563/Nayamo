{
  "name": "nayamo-backend",
  "version": "2.0.0",
  "description": "Clean Nayamo API - Same features, better structure",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "echo 'Backend ready'",
    "test": "jest --coverage --detectOpenHandles",
    "lint": "eslint . --fix",
    "seed": "node seedAdmin.js",
    "pm2:start": "pm2 start pm2.config.js --env production",
    "pm2:stop": "pm2 stop nayamo-api"
  },
  "keywords": ["ecommerce", "jewellery", "react", "nodejs", "mongodb"],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-mongo-sanitize": "^2.3.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.5.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "mongoose-paginate-v2": "^1.10.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.15",
    "razorpay": "^2.9.4",
    "socket.io": "^4.8.0",
    "winston": "^3.15.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.1.0",
    "eslint": "^9.9.1",
    "eslint-config-airbnb-base": "^15.0.0"
  }
}
