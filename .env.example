# ============================================
# Nayamo E-Commerce Backend - Environment Variables
# ============================================

# Server Configuration
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/nayamo?retryWrites=true&w=majority

# JWT Secret (Use strong random string in production, min 32 chars)
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long

# Cloudinary (Image Uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay (Payments)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Delhivery (Shipping)
DELHIVERY_BASE_URL=https://track.delhivery.com
DELHIVERY_TOKEN=your_delhivery_api_token

# CORS Origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

